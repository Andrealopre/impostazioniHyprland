{
    "modules-left": ["custom/power", "hyprland/workspaces"],
    "modules-center": ["custom/media"],
    "modules-right": ["tray", "bluetooth", "network", "battery", "pulseaudio", "clock"],
    

    "custom/power": {
        "format" : "ŌŁś ",
        "tooltip": false,
        "on-click": "wlogout -b 3"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "cursor": true
    },

    "custom/media": {
      "format": "{icon} {0}",
      "format-icons": {
          "spotify": "’å╝",
          "default": "’Ćü"
      },
      "escape": true,
      "return-type": "json",
      "max-length": 40,
      "on-click": "playerctl play-pause",
      "smooth-scrolling-threshold": 10,
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous",
      "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null"
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "cursor": true
    },

    "bluetooth": {
        "format": " ¾░é» ",
        "format-disabled": " ¾░é▓ ",
        "format-connected": " ¾░é▒ ",
        "on-click": "blueman-manager"
    },

    "network": {
        "format-wifi": "’ć½  {essid}",
        "format-ethernet": "Ņ╝ē  Ethernet",
        "format-linked": "’ü×  Linked (No IP)",
        "format-disconnected": "’ü▒  Disconnected",
        "tooltip": false,
        "on-click": "networkmanager_dmenu"
    },

    "battery": {
        "states": {
            "good": 85,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-plugged": "’ā¦ {capacity}%",
        "format-charging": "’ā¦ {capacity}%",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "],
        "tooltip-format": "{time}",
        "cursor": false
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "’æ”  {volume}%",
        "format-bluetooth": "’Ŗö {volume}%",
        "format-bluetooth-muted": "’æ”  {volume}%",
        "format-icons": {
            "headphone": "’Ćź ",
            "headset": "’Ćź ",
            "default": ["’Ć© "]
        },
        "on-click": "pavucontrol"
    },

    "clock": {
        "format": "{:%a %d/%m/%Y ~ %H:%M}",
        "tooltip-format": "<span size='15000'><tt>{calendar}</tt></span>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#F5C2E7'><b>{}</b></span>",
                "weekdays": "<span color='#89B4FA'><b>{}</b></span>",
                "days": "<span color='#CDD6F4'><b>{}</b></span>",
                "today": "<span color='#F9E2AF'><b>{}</b></span>"
            }
        },
        "on-click": "swaync-client -t -sw"
    }
}
